# ==========================================
# STAGE 1: Budowanie klienta (React/Vite)
# ==========================================
FROM node:25-alpine AS client-builder
WORKDIR /build/client

# Instalacja zależności
COPY client/package*.json ./
RUN npm install

# Kopiujemy kod źródłowy klienta
COPY client/ .

# Budujemy aplikację kliencką (Vite domyślnie tworzy folder dist)
RUN npm run build

# ==========================================
# STAGE 2: Finalny obraz serwera (Node.js)
# ==========================================
FROM node:25-alpine
WORKDIR /app

# Kopiujemy pliki konfiguracyjne serwera
COPY server/package*.json ./
COPY server/prisma/ ./prisma/

# Instalacja wszystkich zależności (również devDependencies, żeby pobrać Prisma CLI)
RUN npm install

# Kopiujemy resztę kodu serwera
COPY server/ .

# Generujemy klienta Prisma (schemat jest w folderze prisma)
RUN npx prisma generate

# Usuwamy devDependencies dla lżejszego obrazu produkcyjnego
RUN npm prune --production

# Kopiujemy zbudowanego klienta React do folderu public na serwerze
# (Express jest skonfigurowany, by serwować pliki statyczne z 'public')
COPY --from=client-builder /build/client/dist ./public

EXPOSE 3000
CMD ["npm", "start"]
